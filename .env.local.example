# PostgreSQL (Railway)
DATABASE_URL=postgresql://postgres:password@host:5432/railway

# NextAuth
AUTH_SECRET=                    # openssl rand -base64 32
AUTH_GOOGLE_ID=                 # Google Cloud Console > OAuth 2.0 クライアントID
AUTH_GOOGLE_SECRET=             # Google Cloud Console > OAuth 2.0 クライアントシークレット
NEXTAUTH_URL=http://localhost:3000  # 本番では https://your-domain.com

# Cloudflare R2（アイコン画像アップロード）
R2_ACCOUNT_ID=                  # Cloudflare Dashboard > アカウントID
R2_ACCESS_KEY_ID=               # R2 > APIトークン > アクセスキーID
R2_SECRET_ACCESS_KEY=           # R2 > APIトークン > シークレットアクセスキー
R2_BUCKET_NAME=                 # R2 バケット名
R2_PUBLIC_URL=                  # https://pub-xxxxxxxx.r2.dev（バケットのパブリックURL）
